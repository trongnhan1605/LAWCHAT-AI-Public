APP_NAME=LawChat-AI API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# PostgreSQL only
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/lawchat_ai

SECRET_KEY=replace-with-a-secure-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTO_CREATE_TABLES=true

# Frontend dev server origins allowed by FastAPI
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Embedding configuration
AI_EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
LOCAL_EMBEDDING_BATCH_SIZE=32
LOCAL_EMBEDDING_DEVICE=cpu
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# For 9router/OpenAI-compatible providers, set OPENAI_BASE_URL to that provider's /v1 endpoint
# and use provider-supported model names below. Do not commit real API keys.
# Local 9router example:
# OPENAI_BASE_URL=http://127.0.0.1:20128/v1
# OPENAI_METADATA_MODEL=cx/gpt-5.5
# OPENAI_CHAT_MODEL=cx/gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_TIMEOUT_SECONDS=30

# Optional AI metadata enrichment for upload form autofill
DOCUMENT_METADATA_AI_ENABLED=false
OPENAI_METADATA_MODEL=gpt-4.1-mini
DOCUMENT_METADATA_WEB_SEARCH_ENABLED=false
DOCUMENT_METADATA_TIMEOUT_SECONDS=45

# Optional answer layer defaults
AI_CHAT_ENABLED=false
OPENAI_PUBLIC_CHAT_MODEL=gpt-4.1-mini
OPENAI_CUSTOMER_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CONSULTANT_ASSIST_MODEL=gpt-4.1-mini

# Optional graph backend
GRAPH_BACKEND=relational
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_SYNC_ENABLED=false
NEO4J_TRUST_ALL_CERTIFICATES=false
